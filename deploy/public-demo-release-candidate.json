{
  "contract": "public_demo_release_candidate.v1",
  "status": "release-candidate",
  "release": {
    "id": "public-demo-rc1",
    "label": "ACA Studio Public Demo RC1",
    "surface": "ACA Studio",
    "target_platform": "render-web-service",
    "public_base_url": "https://aca-public-web-demo.onrender.com",
    "version_state": "0.3.0-sprint69",
    "external_ai_required": false,
    "deterministic_runtime": true
  },
  "entrypoints": {
    "root": "https://aca-public-web-demo.onrender.com",
    "studio": "https://aca-public-web-demo.onrender.com/studio",
    "health": "https://aca-public-web-demo.onrender.com/health",
    "runtime_status": "https://aca-public-web-demo.onrender.com/runtime/status",
    "demo_flow": "https://aca-public-web-demo.onrender.com/demo/domain-flow",
    "public_smoke": "https://aca-public-web-demo.onrender.com/deploy/smoke-tests/run",
