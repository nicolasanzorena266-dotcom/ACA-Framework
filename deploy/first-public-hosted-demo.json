{
  "contract": "first_public_hosted_demo.v1",
  "status": "ready",
  "app": {
    "name": "aca-public-web-demo",
    "surface": "ACA Studio",
    "platform": "render-web-service",
    "public_base_url": "https://aca-public-web-demo.onrender.com",
    "mode": "first-public-hosted-demo"
  },
  "runtime": {
    "start_command": "python tools/aca_web.py --host 0.0.0.0",
    "healthcheck_path": "/health",
    "studio_path": "/studio",
    "external_ai_required": false,
    "business_logic_location": "runtime",
    "interface_logic_location": "adapters_and_studio_shell"
  },
  "environment": {
    "PORT": "8765",
    "ACA_HOST": "0.0.0.0",
    "ACA_PUBLIC_BASE_URL": "https://aca-public-web-demo.onrender.com",
    "ACA_DOMAIN_PACK_ROOT": "examples/domain_packs",
    "ACA_DEFAULT_DOMAIN_PACK": "example.customer_support",
    "ACA_STUDIO_PATH": "studio/index.html"
  },
  "public_urls": {
    "root": "https://aca-public-web-demo.onrender.com",
    "studio": "https://aca-public-web-demo.onrender.com/studio",
    "health": "https://aca-public-web-demo.onrender.com/health",
    "runtime_status": "https://aca-public-web-demo.onrender.com/runtime/status",
