{
  "contract": "public_web_demo_prep.v1",
  "demo_name": "aca-public-web-demo",
  "public_base_url": "https://aca-demo.example.com",
  "runtime": "python",
  "web_package": {
    "contract": "deployable_web_package.v1",
    "app_name": "aca-public-web-demo",
    "runtime": "python",
    "python_version": ">=3.10",
    "process": {
      "type": "web",
      "command": "python tools/aca_web.py --host 0.0.0.0",
      "local_command": "python tools/aca_web.py --host 127.0.0.1 --port 8765 --open",
      "host": "0.0.0.0",
      "port_env": "PORT",
      "fallback_port": 8765
    },
    "healthcheck": {
      "method": "GET",
      "path": "/health",
      "expected_status": 200,
      "expected_json_status": "ok"
    },
    "routes": {
      "studio": "/studio",
      "health": "/health",
      "runtime_status": "/runtime/status",
      "studio_binding": "/studio/binding",
      "demo_domain_flow": "/demo/domain-flow"
    },
    "assets": {
      "studio_html": "studio/index.html",
      "domain_pack_root": "examples/domain_packs"
    },
    "environment": {
      "ACA_HOST": "0.0.0.0",
      "ACA_PORT": "8765",
      "PORT": "8765",
      "ACA_DOMAIN_PACK_ROOT": "examples/domain_packs"
    },
    "required_files": [
      "tools/aca_web.py",
      "aca_os/runtime_rest.py",
      "aca_os/runtime_api_endpoints.py",
      "studio/index.html",
      "examples/domain_packs",
      "pyproject.toml"
    ],
    "non_goals": [
      "no LLM dependency",
      "no external AI service requirement",
      "no business logic in deployment wrapper"
    ],
    "local_runtime_plan": {
      "contract": "local_web_runtime_launcher.v1",
      "config": {
        "host": "127.0.0.1",
        "port": 8765,
        "base_url": "http://127.0.0.1:8765",
        "studio_url": "http://127.0.0.1:8765/studio",
        "health_url": "http://127.0.0.1:8765/health",
        "api_base_url": "http://127.0.0.1:8765",
        "studio_path": "studio/index.html",
        "open_browser": true
      },
      "endpoints": {
        "studio": "http://127.0.0.1:8765/studio",
        "health": "http://127.0.0.1:8765/health",
        "runtime_status": "http://127.0.0.1:8765/runtime/status",
        "studio_state": "http://127.0.0.1:8765/studio/state",
        "studio_run": "http://127.0.0.1:8765/studio/run",
        "domain_packs": "http://127.0.0.1:8765/runtime/domain-packs"
      },
      "commands": {
        "start": "python tools/aca_web.py --host 127.0.0.1 --port 8765",
        "health_check": "python -c \"import urllib.request; print(urllib.request.urlopen('http://127.0.0.1:8765/health').read().decode())\"",
        "stop": "Ctrl+C"
      }
    }
  },
  "startup": {
    "command": "python tools/aca_web.py --host 0.0.0.0",
    "port_env": "PORT",
    "healthcheck_path": "/health"
