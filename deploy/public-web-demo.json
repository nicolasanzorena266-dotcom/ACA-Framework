      "command": "python tools/aca_web.py --host 127.0.0.1 --port 8765 --open",
      "expect": "Studio opens at http://127.0.0.1:8765/studio"
    },
    {
      "step": 5,
      "name": "Start web runtime on platform",
      "command": "python tools/aca_web.py --host 0.0.0.0",
      "expect": "Runtime binds to the platform provided PORT"
