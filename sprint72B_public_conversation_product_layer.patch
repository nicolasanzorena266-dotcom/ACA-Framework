index 0000000..766633d
--- /dev/null
+++ b/aca_os/public_conversation_product_layer.py
@@ -0,0 +1,222 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any, Dict, Iterable, Mapping
+
+from aca_core import PluginRuntime
+
+CONTRACT = "public_conversation_product_layer.v1"
+SURFACE = "client_support"
+
+PUBLIC_ACTIONS = {
+    "can_show_process": "Ver proceso público",
+    "can_show_diagnostic": "Ver diagnóstico",
+    "can_prepare_handoff": "Preparar resumen para derivación",
+    "can_generate_case_summary": "Generar resumen del caso",
+    "real_representative_transfer": "Derivar con representante",
+}
+
+BLOCKED_CAPABILITY_LABELS = {
+    "real_claim_status_lookup": "consulta real de estado",
+    "real_document_upload": "carga real de documentación",
+    "real_representative_transfer": "transferencia real a representante",
+}
+
+TECHNICAL_LANGUAGE_BLOCKLIST = (
+    "developer_trace",
+    "policy blocked",
+    "selected_program",
+    "pluginruntime",
+    "traceback",
+    "raw runtime",
+    "blocked_capabilities",
+)
+
+
+def build_public_conversation_product_layer(
+    *,
+    message: str,
+    conversation_id: str = "public-demo",
+    plugin_root: str | Path = "plugins",
+    requested_capability: str | None = None,
+) -> Dict[str, Any]:
+    """Build the public product surface over the plugin-based runtime.
+
+    This is deliberately a transformation layer. The public payload never points
+    the UI at the developer trace directly; it projects that trace into public
+    process and diagnostic views first.
+    """
+
+    runtime = PluginRuntime.from_path(plugin_root)
+    inferred_capability = requested_capability or _infer_route_capability(message)
+    developer_result = runtime.process(
+        message,
+        conversation_id=conversation_id,
+        requested_capability=inferred_capability,
+    ).to_dict()
+
+    selected_plugin_id = developer_result["route"].get("selected_plugin_id")
+    selected_capability = developer_result["route"].get("selected_capability")
+    selected_plugin = runtime.plugin_registry.get(selected_plugin_id) if selected_plugin_id else None
+    blocked_capabilities = tuple(selected_plugin.blocked_capabilities) if selected_plugin else ()
+    blocked_claims = _blocked_claims_for_message(message, blocked_capabilities)
+
+    actions = _visible_actions(runtime, selected_plugin_id)
+    visible_response = _visible_response(
+        message=message,
+        selected_plugin_id=selected_plugin_id,
+        selected_capability=selected_capability,
+        blocked_claims=blocked_claims,
+    )
+
+    public_process_view = _public_process_view(developer_result)
+    diagnostic_view = _diagnostic_view(developer_result, actions, blocked_claims)
+
+    payload: Dict[str, Any] = {
+        "contract": CONTRACT,
+        "surface": SURFACE,
+        "message": message,
+        "conversation_id": conversation_id,
+        "active_plugin": {
+            "id": selected_plugin_id,
+            "display_name": selected_plugin.manifest.plugin.display_name if selected_plugin else None,
+            "type": selected_plugin.manifest.plugin.type if selected_plugin else None,
+        },
+        "active_capability": selected_capability,
+        "visible_response": visible_response,
+        "actions": actions,
+        "public_process_view": public_process_view,
+        "diagnostic_view": diagnostic_view,
+        "claim_filter": {
+            "blocked_capability_claims": list(blocked_claims),
+            "allowed_action_capabilities": [action["capability"] for action in actions if action["enabled"]],
+            "blocked_language": list(TECHNICAL_LANGUAGE_BLOCKLIST),
+        },
+        "developer_trace_exposed_to_public": False,
+        "developer_trace": developer_result,
+    }
+    payload["validation"] = validate_public_conversation_product_layer(payload)
+    return payload
+
+
+def validate_public_conversation_product_layer(layer: Mapping[str, Any] | None = None) -> Dict[str, Any]:
+    layer = dict(layer or {})
+    public_text = "\n".join(
+        str(layer.get(key, ""))
+        for key in ("visible_response", "public_process_view", "diagnostic_view")
+    ).lower()
+    leaked_terms = [term for term in TECHNICAL_LANGUAGE_BLOCKLIST if term in public_text]
+    actions = layer.get("actions") or []
+    public_sections = ("public_process_view", "diagnostic_view")
+    public_trace_leaks = [section for section in public_sections if "developer_trace" in str(layer.get(section, ""))]
+
+    status = "pass" if not leaked_terms and not public_trace_leaks and isinstance(actions, list) else "fail"
+    return {
+        "contract": "public_conversation_product_layer.validation.v1",
+        "status": status,
+        "checks": {
+            "public_trace_is_projected": not public_trace_leaks,
+            "technical_language_blocked": not leaked_terms,
+            "actions_are_capability_based": isinstance(actions, list),
+        },
+        "leaked_terms": leaked_terms,
+        "trace_leak_sections": public_trace_leaks,
+    }
+
+
+def _infer_route_capability(message: str) -> str | None:
+    text = _normalize(message)
+    if any(token in text for token in ("cristal", "vidrio", "parabrisas")):
+        return "insurance.glass"
+    if any(token in text for token in ("siniestro", "denuncia", "choque", "accidente", "cobertura", "poliza")):
+        return "insurance.claims"
+    return None
+
+
+def _blocked_claims_for_message(message: str, blocked_capabilities: Iterable[str]) -> tuple[str, ...]:
+    text = _normalize(message)
+    blocked = set(blocked_capabilities)
+    claims: list[str] = []
+    if "real_claim_status_lookup" in blocked and any(token in text for token in ("estado", "seguimiento", "ticket", "siniestro")):
+        claims.append("real_claim_status_lookup")
+    if "real_document_upload" in blocked and any(token in text for token in ("subir", "adjuntar", "cargar", "documentacion", "foto")):
+        claims.append("real_document_upload")
+    if "real_representative_transfer" in blocked and any(token in text for token in ("representante", "asesor", "persona", "supervisor")):
+        claims.append("real_representative_transfer")
+    return tuple(dict.fromkeys(claims))
+
+
+def _visible_actions(runtime: PluginRuntime, plugin_id: str | None) -> list[Dict[str, Any]]:
+    if not plugin_id:
+        return []
+    actions: list[Dict[str, Any]] = []
+    for capability, label in PUBLIC_ACTIONS.items():
+        providers = runtime.capability_registry.providers_for(capability)
+        blocked = not runtime.policy_engine.allows(plugin_id, capability)
+        if plugin_id in providers or capability.startswith("real_"):
+            actions.append(
+                {
+                    "id": capability.replace(".", "_").replace("-", "_"),
+                    "label": label,
+                    "capability": capability,
+                    "enabled": plugin_id in providers and not blocked,
+                    "reason": "declared_by_active_plugin" if plugin_id in providers and not blocked else "not_declared_or_blocked",
+                }
+            )
+    return actions
+
+
+def _visible_response(
+    *,
+    message: str,
+    selected_plugin_id: str | None,
+    selected_capability: str | None,
+    blocked_claims: tuple[str, ...],
+) -> str:
+    if blocked_claims:
+        labels = ", ".join(BLOCKED_CAPABILITY_LABELS.get(claim, claim) for claim in blocked_claims)
+        return (
+            "Puedo orientarte con la información disponible y preparar un resumen útil, "
+            f"pero no puedo ejecutar {labels}. Para avanzar sin inventar datos, necesito trabajar con lo que me cuentes acá."
+        )
+    if selected_plugin_id == "generic.open_chat":
+        return "Puedo ayudarte a ordenar la consulta y definir el próximo paso sin asumir un negocio específico."
+    if selected_capability:
+        return "Puedo orientar la conversación desde la capacidad activa y dejar el proceso visible sin exponer detalle técnico."
+    return "No encontré una capacidad suficiente para resolverlo; puedo pedir una aclaración breve o continuar en modo abierto."
+
+
+def _public_process_view(developer_result: Mapping[str, Any]) -> Dict[str, Any]:
+    route = dict(developer_result.get("route") or {})
+    state = dict(developer_result.get("state") or {})
+    return {
+        "contract": "public_process_view.v1",
+        "summary": "ACA eligió una capacidad disponible y actualizó el estado de conversación aislado para esa capacidad.",
+        "active_plugin_id": route.get("selected_plugin_id"),
+        "active_capability": route.get("selected_capability"),
+        "state_version": state.get("version"),
+        "next_step": "Continuar la conversación o ejecutar una acción visible declarada por el plugin activo.",
+    }
+
+
+def _diagnostic_view(
+    developer_result: Mapping[str, Any],
+    actions: list[Mapping[str, Any]],
+    blocked_claims: tuple[str, ...],
+) -> Dict[str, Any]:
+    route = dict(developer_result.get("route") or {})
+    enabled = [action["capability"] for action in actions if action.get("enabled")]
+    return {
+        "contract": "diagnostic_view.v1",
+        "route_reason": route.get("reason"),
+        "confidence_score": route.get("score", 0),
+        "enabled_action_capabilities": enabled,
+        "blocked_capability_claims": list(blocked_claims),
+        "diagnosis": "La capa pública puede mostrar diagnóstico resumido sin consumir la traza técnica cruda.",
+    }
+
+
+def _normalize(value: str) -> str:
+    replacements = str.maketrans("áéíóúüñ", "aeiouun")
+    return " ".join(str(value or "").lower().translate(replacements).split())
diff --git a/tests/test_public_conversation_product_layer.py b/tests/test_public_conversation_product_layer.py
new file mode 100644
index 0000000..1885fc9
--- /dev/null
+++ b/tests/test_public_conversation_product_layer.py
@@ -0,0 +1,102 @@
+from __future__ import annotations
+
+import shutil
+from pathlib import Path
+
+from aca_os.public_conversation_product_layer import (
+    build_public_conversation_product_layer,
+    validate_public_conversation_product_layer,
+)
+
+
+def test_public_layer_projects_developer_trace_without_exposing_it() -> None:
+    layer = build_public_conversation_product_layer(
+        message="Necesito saber el estado del siniestro 12345",
+        conversation_id="public-72b",
+        plugin_root="plugins",
+    )
+
+    assert layer["contract"] == "public_conversation_product_layer.v1"
+    assert layer["surface"] == "client_support"
+    assert layer["active_plugin"]["id"] == "galicia.insurance"
+    assert layer["active_capability"] == "insurance.claims"
+    assert layer["developer_trace_exposed_to_public"] is False
+    assert "developer_trace" in layer
+    assert "developer_trace" not in str(layer["public_process_view"])
+    assert "developer_trace" not in str(layer["diagnostic_view"])
+    assert layer["validation"]["status"] == "pass"
+
+
+def test_public_actions_are_derived_from_plugin_capabilities() -> None:
+    layer = build_public_conversation_product_layer(
+        message="Tuve un choque y necesito preparar el reclamo",
+        conversation_id="actions-72b",
+        plugin_root="plugins",
+    )
+    actions = {action["capability"]: action for action in layer["actions"]}
+
+    assert actions["can_show_process"]["enabled"] is True
+    assert actions["can_show_diagnostic"]["enabled"] is True
+    assert actions["can_prepare_handoff"]["label"] == "Preparar resumen para derivación"
+    assert actions["can_generate_case_summary"]["enabled"] is True
+    assert actions["real_representative_transfer"]["enabled"] is False
+    assert actions["real_representative_transfer"]["reason"] == "not_declared_or_blocked"
+
+
+def test_blocked_capability_claims_do_not_leak_as_promises() -> None:
+    layer = build_public_conversation_product_layer(
+        message="Quiero consultar el estado del siniestro y subir documentación",
+        conversation_id="claims-72b",
+        plugin_root="plugins",
+    )
+
+    blocked = set(layer["claim_filter"]["blocked_capability_claims"])
+    public_text = layer["visible_response"].lower()
+
+    assert "real_claim_status_lookup" in blocked
+    assert "real_document_upload" in blocked
+    assert "consulté" not in public_text
+    assert "ya cargué" not in public_text
+    assert "no puedo ejecutar" in public_text
+
+
+def test_generic_open_chat_remains_public_base_without_business_plugin(tmp_path: Path) -> None:
+    plugins_root = tmp_path / "plugins"
+    plugins_root.mkdir()
+    shutil.copytree(Path("plugins") / "generic.open_chat", plugins_root / "generic.open_chat")
+
+    layer = build_public_conversation_product_layer(
+        message="Hola, necesito ordenar una consulta cualquiera",
+        conversation_id="generic-72b",
+        plugin_root=plugins_root,
+    )
+
+    assert layer["active_plugin"]["id"] == "generic.open_chat"
+    assert layer["active_capability"] == "generic.open_chat"
+    assert "galicia" not in str(layer["public_process_view"]).lower()
+    assert "can_show_process" in layer["claim_filter"]["allowed_action_capabilities"]
+
+
+def test_public_layer_validation_blocks_technical_language() -> None:
+    validation = validate_public_conversation_product_layer(
+        {
+            "visible_response": "policy blocked tool claim",
+            "public_process_view": {"summary": "ok"},
+            "diagnostic_view": {"summary": "ok"},
+            "actions": [],
+        }
+    )
+
+    assert validation["status"] == "fail"
+    assert "policy blocked" in validation["leaked_terms"]
+
+
+def test_studio_declares_public_product_layer_markers() -> None:
+    html = Path("studio/index.html").read_text(encoding="utf-8")
+
+    assert "Public Conversation Product Layer" in html
+    assert "PUBLIC_CONVERSATION_LAYER_ENDPOINT" in html
+    assert "publicProcessView" in html
+    assert "diagnosticView" in html
+    assert "developer_trace → public_process_view" in html
+    assert "Preparar resumen para derivación" in html
