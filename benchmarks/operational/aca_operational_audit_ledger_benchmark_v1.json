  "scenarios": [
    {
      "id": "LEDGER-001",
      "type": "low_risk_preparation",
      "context": "A low-risk prepared follow-up needs a complete ledger even without a tool.",
      "work_fixture": {
        "operation": "prepare_claim_follow_up",
        "category": "preparatory",
        "expected_outcome": "prepared",
        "evidence": {"source": "candidate_work", "claim_loaded": true}
      },
      "ledger_context": {
        "conversation_id": "ledger-001",
        "timestamp": "2026-07-13T10:00:00+00:00"
      },
      "expected_ledger": {
        "complete": true,
        "audit_trace_complete": true,
        "idempotency_covered": true,
        "receipt_covered": true,
        "compensation_covered": true,
        "replay_safe": true,
        "duplicate_detected": false,
        "execution_status": "would_execute"
      }
    },
    {
      "id": "LEDGER-002",
      "type": "external_write",
      "context": "A governed ticket creation projects request, idempotency and shadow receipt.",
      "work_fixture": {
        "operation": "open_ticket",
        "category": "coordinative",
        "expected_outcome": "prepared"
      },
      "tool_contracts": {
        "ticket_create": {
          "deterministic": false,
          "has_side_effects": true,
          "supports_dry_run": true,
          "supports_replay": true,
          "supports_shadow": false,
          "idempotency": "idempotent",
          "guarantee": "External ticket API returns stable ticket id."
        }
      },
      "governance_context": {
        "available_evidence": ["issue_summary"],
        "permissions": {"execute:open_ticket": true},
        "user_confirmation": true
      },
      "ledger_context": {
        "conversation_id": "ledger-002",
        "timestamp": "2026-07-13T10:01:00+00:00",
        "shadow_external_receipt": {"status": "not_created_shadow"}
      },
      "expected_ledger": {
        "complete": true,
        "audit_trace_complete": true,
        "idempotency_covered": true,
        "receipt_covered": true,
        "compensation_covered": true,
        "replay_safe": true,
        "duplicate_detected": false,
        "execution_status": "would_execute"
      }
    },
