      "type": "tool_unavailable",
      "context": "Document association is blocked by public capability manifest.",
      "work_fixture": {
        "operation": "associate_documentation",
        "category": "administrative",
        "expected_outcome": "prepared"
      },
      "plugin_manifests": [
        {
          "plugin": {"id": "galicia.insurance"},
          "blocked_capabilities": ["insurance.document.upload"],
          "public_actions": [
            {
              "id": "document_upload",
              "capability": "insurance.document.upload",
              "enabled": false,
              "disabled_reason": "No document upload tool connected."
            }
          ]
        }
      ],
      "governance_context": {
        "available_evidence": ["case_reference", "documents"],
        "permissions": {"execute:associate_documentation": true},
        "user_confirmation": true
      },
      "expected_governance": {
        "risk_level": 3,
        "execution_allowed": false,
        "requires_confirmation": true,
        "requires_human_approval": false,
        "tool_available": false,
        "idempotency_safe": false,
        "missing_preconditions_contains": ["tool_unavailable"]
      }
    },
