{
  "benchmark": "aca_operational_governance_benchmark.v1",
  "description": "Shadow benchmark for validating whether already-selected operational work would be safe to execute under production governance rules.",
  "domain": "operational_governance",
  "scenarios": [
    {
      "id": "GOV-001",
      "type": "informational",
      "context": "Informative operation has no external side effect.",
      "work_fixture": {
        "operation": "explain_domain_concept",
        "category": "informative",
        "expected_outcome": "explained"
      },
      "expected_governance": {
        "risk_level": 0,
        "execution_allowed": true,
        "requires_confirmation": false,
        "requires_human_approval": false,
        "tool_available": true,
        "idempotency_safe": true
      }
    },
    {
      "id": "GOV-002",
      "type": "preparatory",
      "context": "Claim follow-up preparation produces no external write.",
      "work_fixture": {
        "operation": "prepare_claim_follow_up",
        "category": "preparatory",
        "expected_outcome": "prepared",
        "evidence": {"source": "candidate_work", "claim_loaded": true}
      },
      "expected_governance": {
        "risk_level": 1,
        "execution_allowed": true,
        "requires_confirmation": false,
        "requires_human_approval": false,
        "tool_available": true,
        "idempotency_safe": true
      }
    },
    {
      "id": "GOV-003",
      "type": "external_write",
      "context": "Opening a ticket without a tool contract must be blocked.",
      "work_fixture": {
        "operation": "open_ticket",
        "category": "coordinative",
        "expected_outcome": "prepared",
        "evidence": {"source": "candidate_work"}
      },
      "governance_context": {
        "available_evidence": ["issue_summary"],
        "permissions": {"execute:open_ticket": true},
        "user_confirmation": true
      },
      "expected_governance": {
        "risk_level": 3,
        "execution_allowed": false,
        "requires_confirmation": true,
        "requires_human_approval": false,
        "tool_available": false,
        "idempotency_safe": false,
        "missing_preconditions_contains": ["tool_unavailable", "idempotency_unknown"]
      }
    },
    {
      "id": "GOV-004",
      "type": "external_write",
      "context": "Opening a ticket with evidence, permission, confirmation and safe tool can execute.",
      "work_fixture": {
        "operation": "open_ticket",
        "category": "coordinative",
        "expected_outcome": "prepared"
      },
      "tool_contracts": {
        "ticket_create": {
          "deterministic": false,
          "has_side_effects": true,
          "supports_dry_run": true,
          "supports_replay": true,
          "supports_shadow": false,
          "idempotency": "idempotent",
          "guarantee": "External ticket API returns stable ticket id."
        }
      },
      "governance_context": {
        "available_evidence": ["issue_summary"],
        "permissions": {"execute:open_ticket": true},
        "user_confirmation": true
      },
      "expected_governance": {
        "risk_level": 3,
        "execution_allowed": true,
        "requires_confirmation": true,
        "requires_human_approval": false,
        "tool_available": true,
        "idempotency_safe": true
      }
    },
    {
      "id": "GOV-005",
      "type": "double_execution",
      "context": "A visit scheduler that requires idempotency key must be blocked if the key is missing.",
      "work_fixture": {
        "operation": "schedule_technical_visit",
        "category": "coordinative",
        "expected_outcome": "prepared"
      },
      "tool_contracts": {
        "technical_visit_scheduler": {
          "deterministic": false,
          "has_side_effects": true,
          "supports_dry_run": true,
          "supports_replay": true,
          "supports_shadow": false,
          "idempotency": "requires_idempotency_key",
          "guarantee": "Provider accepts idempotency key."
        }
      },
      "governance_context": {
        "available_evidence": ["technical_diagnosis", "service_address"],
        "permissions": {"execute:schedule_technical_visit": true},
        "user_confirmation": true
      },
      "expected_governance": {
        "risk_level": 3,
        "execution_allowed": false,
        "requires_confirmation": true,
        "requires_human_approval": false,
        "tool_available": true,
        "idempotency_safe": false,
        "missing_preconditions_contains": ["idempotency_key_required"]
      }
    },
    {
      "id": "GOV-006",
      "type": "missing_evidence",
      "context": "A visit request with safe tool still needs service address.",
      "work_fixture": {
        "operation": "schedule_technical_visit",
